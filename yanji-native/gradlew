#!/bin/sh
# Gradle wrapper — downloads gradle if not cached
set -e
APP_NAME="Gradle"
DIRNAME=$(dirname "$0")
CLASSPATH="$DIRNAME/gradle/wrapper/gradle-wrapper.jar"

# Download wrapper jar if missing
if [ ! -f "$CLASSPATH" ]; then
    WRAPPER_URL="https://services.gradle.org/distributions/gradle-8.11.1-bin.zip"
    echo "Downloading Gradle wrapper..."
    mkdir -p "$DIRNAME/gradle/wrapper"
    # Use gradle wrapper from gradle itself
    if command -v gradle >/dev/null 2>&1; then
        cd "$DIRNAME" && gradle wrapper --gradle-version 8.11.1 && exit 0
    fi
    echo "Please run: gradle wrapper --gradle-version 8.11.1"
    exit 1
fi

exec java -classpath "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain "$@"
